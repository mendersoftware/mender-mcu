{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    ":gitSignOff",
    ":rebaseStalePrs"
  ],

  // CODEOWNERS drives reviewer assignment. Keep CODEOWNERS complete.
  "reviewersFromCodeOwners": true,

  // chore(deps): <desc>, matching the old Dependabot prefix. CI files get ci: below.
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",

  // Drain backlogs gradually. 10 concurrent because there are three base branches.
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,

  "baseBranchPatterns": ["main", "1.0.x"],

  // Security PRs bypass the schedule
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "labels": ["security"]
  },

  "packageRules": [
    {
      // TODO: remove some of these when we ditch dependabot
      "matchCategories": ["python", "docker", "ci"],
      "enabled": false
    },
    {
      // TODO: remove  when we ditch dependabot
      "matchManagers": ["git-submodules"],
      "enabled": false
    },
  ],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/.gitlab-ci.yml/"],
      "matchStrings": [
        "MENDER_ARTIFACT_VERSION:[\\s\\S]*?value:\\s*[\"']?(?<currentValue>[\\d\\.]+)[\"']?"
      ],
      "depNameTemplate": "mendersoftware/mender-artifact",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "semver"
    },
  ],
}
